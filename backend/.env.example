# ── Database (Supabase Postgres — transaction/pooler mode) ────────────────────
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Twilio WhatsApp Sandbox ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886   # Twilio sandbox number

# ── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_me_in_production_use_32_random_bytes
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Claude Model ─────────────────────────────────────────────────────────────
# Use claude-sonnet-4-5; swap to claude-sonnet-4-6 when available
CLAUDE_MODEL=claude-sonnet-4-5
